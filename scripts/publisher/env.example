# Publisher — Environment Variables
# Copy to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────

# Publisher wallet private key (must be registered in PublisherStake)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Monad RPC endpoint
RPC_URL=https://rpc.monad.xyz

# ScoreRegistry contract address (from deploy.js output)
REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# Monad chain ID
# Mainnet: 143 | Testnet: 10143
CHAIN_ID=143

# ── Optional ──────────────────────────────────────────────────────────────────

# Enables AI score augmentation via Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Minutes between publish runs (default: 30)
PUBLISH_INTERVAL_MIN=30

# Skip pools with risk score below this threshold (default: 0 = publish all)
MIN_RISK_SCORE=0

# Max pools to process per run (default: 20)
MAX_POOLS_PER_RUN=20

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info
